{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "overlay",
  "description": "Overlay window minimal permissions, data is pushed from backend via events",
  "windows": ["overlay"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:event:allow-listen"
  ]
}
